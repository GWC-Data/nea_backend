######################
# Example env config #
######################

# General env setting
NODE_ENV=dev

# Port that the app is serving
PORT=6060

# Port on which metrics and analytics data is served. It is used to allow different firewall rules for accessing the service
SECONDARY_PORT=6061

# Service name for logging and tracing
CHART=~~NEA~~ 

# Debug namespaces (comma-separated, supports wildcards)
DEBUG=engine.* 

# Logging format: 'local' (colorized) or 'json' (structured). Auto-detects if not set.
LOG_FORMAT=local

# Show detailed logs with stack traces and verbose data
DETAILED_LOGS=false

# Database migrations
RUN_DB_MIGRATION=true

DB_MIGRATIONS_DIR=src/db/migrations

########################
# Token Authentication #
########################

# Audience requirement of the current service
ACCESS_TOKEN_AUDIENCE=nea

# Issuer requirement of the current service
ACCESS_TOKEN_ISSUER=nea

ACCESS_TOKEN_EXPIRATION_TIME=3600

# Private key path for JWT signing (used in non-test environments)
PRIVATE_KEY_PATH=keys/private-key.pem

# JWT secret for test environment only
# This is ONLY used when NODE_ENV=test
# JWT_SECRET=test-secret-key-for-jwt-please-change-in-production

########################
# SQL CONNECTION #
########################

SQL_TYPE=mysql

SQL_HOST=localhost
# SQL_HOST=35.200.169.120

SQL_PORT=3306

SQL_DB=nea_office

# SQL_USER=root
SQL_USER=appuser

# SQL_PASSWORD=123456789
SQL_PASSWORD=pass 

########################
# Pub/Sub Configuration #
########################

# Enable or disable Pub/Sub functionality
ENABLE_PUBSUB=false

# Google Cloud Pub/Sub Topic (for publishing messages)
PUBSUB_TOPIC=

# Google Cloud Pub/Sub Subscription (for consuming messages)
PUBSUB_SUBSCRIPTION=

# Additional topics/subscriptions can be added as needed
# PUBSUB_EVENT_TOPIC=
# PUBSUB_NOTIFICATION_TOPIC=
# PUBSUB_ANOTHER_SUBSCRIPTION=